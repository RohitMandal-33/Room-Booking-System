<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Day theme: transparent system bars so Compose edge-to-edge + SystemBarAppearance control contrast -->
    <style name="Theme.BookingSystem" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorBackground">#FFF4F6FA</item>
        <item name="android:windowBackground">#FFF4F6FA</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:enforceStatusBarContrast">false</item>
    </style>
</resources>
